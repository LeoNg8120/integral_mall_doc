{
  "root": ".",
  "title": "积分商城开发文档",
  "description": "积分商城 Integral Mall 完整技术文档",
  "author": "Integral Mall Team",
  "language": "zh-hans",
  "gitbook": ">=3.0.0",
  "plugins": [
    "mermaid",
    "prism",
    "-highlight",
